---
import { Icon } from "astro-icon/components";

import { __ } from "../utils/i18n";
import {
  SITE,
  MENU,
  BANNER,
  BANNER_SRCSET,
  TRIANGLE_BADGE,
} from "../utils/config";
import { urlFor } from "../utils/urlFor";

import HeaderLink from "./partial/HeaderLink.astro";
import RssBtn from "./partial/RssBtn";
import SearchBtn from "./partial/SearchBtn";
import ThemeBtn from "./partial/ThemeBtn";
import SearchBox from "./partial/SearchBox";
import LanguageBtn from "./partial/LanguageBtn";

type Props = {
  title?: string;
  cover?: string;
};

const { title = SITE.title, cover } = Astro.props;
---

<div id="header-nav">
  <nav id="main-nav">
    {
      MENU.map((item) => (
        <HeaderLink href={urlFor(item.url)} aria-label={item.name}>
          {__(item.name)}
        </HeaderLink>
      ))
    }
    <span
      id="main-nav-toggle"
      class="nav-icon"
      aria-label="Toggle navigation"
      role="button"
    >
      <Icon name="fa6-solid:bars" size={14} />
    </span>
  </nav>

  <nav id="sub-nav" aria-label="Secondary navigation">
    <RssBtn client:load href={urlFor("rss.xml")} className="nav-icon" />
    <ThemeBtn client:load className="nav-icon" />
    <LanguageBtn client:load className="nav-icon" />
    
    <div id="search-wrapper">
      <SearchBtn client:load className="nav-icon" />
      <div id="inline-search-bar" class="search-hidden">
        <input type="text" id="local-search-input" placeholder={__('search_placeholder')} />
      </div>
      <div id="search-results-portal">
        <SearchBox
          client:idle
          searchIndexUrl={urlFor("search.json")}
          postUrlPrefix={urlFor("blog")}
          imageUrl={urlFor("images/reimu.png")}
        />
      </div>
    </div>
  </nav>

  {
    TRIANGLE_BADGE.enable && (
      <a
        href={TRIANGLE_BADGE.link}
        class="triangle-badge"
        title={TRIANGLE_BADGE.type}
        target="_blank"
        rel="noopener nofollow noreferrer"
      >
        <Icon name={`fa6-brands:${TRIANGLE_BADGE.type}`} class="triangle-badge-icon" />
      </a>
    )
  }
</div>

<header id="header">
  {
    cover ? (
      <img src={urlFor(cover)} alt={title} fetchpriority="high" />
    ) : BANNER_SRCSET.enable ? (
      <picture style="user-select: none;">
        {BANNER_SRCSET.srcset.map((source) => (
          <source media={source.media} srcset={urlFor(source.src)} />
        ))}
        <img src={urlFor(BANNER)} alt={title} fetchpriority="high" />
      </picture>
    ) : (
      <img src={urlFor(BANNER)} alt={title} fetchpriority="high" />
    )
  }
  <div id="header-outer" class="outer">
    <div id="header-title" class="inner">
      <slot />
    </div>
  </div>
</header>

<script>
  const initHeaderScroll = () => {
    const headerNav = document.getElementById("header-nav");
    if (!headerNav) return;

    const scrollRange = 200; 
    const handleScroll = () => {
      const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
      const fraction = Math.min(scrollTop / scrollRange, 1);
      const offset = fraction * headerNav.offsetHeight;
      const opacity = 1 - fraction;

      window.requestAnimationFrame(() => {
        headerNav.style.transform = `translateY(-${offset}px)`;
        headerNav.style.opacity = opacity.toString();
      });
    };
    window.addEventListener("scroll", handleScroll, { passive: true });
  };

  const initClickOutside = () => {
    document.addEventListener('click', (e) => {
      const langList = document.getElementById('lang-list');
      if (langList && !(e.target as Element).closest('.lang-btn-container')) {
        langList.classList.remove('show');
      }
    });
  };

  document.addEventListener('astro:page-load', () => {
    initHeaderScroll();
    initClickOutside();
  });
</script>

<style lang="stylus">
/* --- 1. Header Navigation Bar --- */
#header-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60px;
  padding: 0 20px;
  background: var(--color-header-background);
  box-shadow: var(--shadow-card);
  z-index: 200;
  transition: background 1s, opacity 0.3s;
  will-change: transform, opacity;

  &:hover {
    background: rgba(255, 255, 255, 0.95);
  }
}

#main-nav {
  display: flex;
  align-items: center;
  gap: 30px;
}

#sub-nav {
  display: flex;
  align-items: center;
  gap: 10px;
}

:global(.nav-icon) {
  color: var(--red-0);
  opacity: 0.8;
  text-decoration: none;
  transition: 0.2s;
  padding: 25px 25px;
  text-align: center;
  font-size: 18px;
  width: 18px;
  height: 18px;
  will-change: transform;
  cursor: pointer;

  &:hover {
    opacity: 1;
    transform: scale(1.1);
  }
}

/* --- 2. Banner Header --- */
#header {
  min-height: 400px;
  height: 35vh;
  position: relative;

  img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 180%;
    z-index: -2;
    user-select: none;
    display: block;
    object-fit: cover;
    transition: 0.3s;
    -webkit-mask: linear-gradient(to top, transparent, #fff 50%);
    mask: linear-gradient(to top, transparent, #fff 50%);

    @media screen and (max-width: 959px) {
      height: 120%;
    }
    @media screen and (max-width: 767px) {
      height: 100%;
    }
  }
}

#header-outer {
  height: 100%;
  position: relative;
  max-width: 100%;
}

#header-title {
  font-weight: 700;
  text-align: center;
  position: absolute;
  top: 50%;
  margin: 40px * -0.5 2.5% 0;
  width: 95%;
  opacity: 0;
  filter: blur(8px);
  will-change: transform, opacity, filter;
  animation: fade-in-blur 800ms ease-out 200ms forwards;
}

/* --- 3. Search Components --- */
#search-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  height: 100%;
  align-self: stretch;
}

#search-results-portal {
  position: absolute;
  top: calc(100% - 1px);
  right: 0;
  width: auto;
  min-width: 300px;
}

#inline-search-bar {
  width: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  background: rgba(0,0,0,0.05);
  border-radius: 20px;
  display: flex;
  align-items: center;

  &.search-active {
    width: 200px;
    opacity: 1;
    padding: 5px 15px;
    margin-right: 10px;
  }

  input {
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
  }
}

:global(.search-result-popup) {
  position: absolute;
  top: 0 !important;
  right: 0;
  width: 300px;
  background: var(--color-header-background);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-top: none !important;
  border-radius: 0 0 12px 12px;
  margin-top: 0 !important;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
  z-index: 1001;
  animation: search-slide-in 0.2s ease-out;
}

:global(.reimu-hit-item) {
  padding: 0 !important;
  transition: background 0.2s;
}

:global(.reimu-hit-item:hover) {
  background: rgba(255, 0, 0, 0.05);
}

:global(.reimu-hit-item a) {
  display: block;
  padding: 12px 20px;
  text-decoration: none;
}

:global(.hit-title) {
  color: var(--red-0);
  font-weight: 600;
  font-size: 14px;
  margin-bottom: 4px;
}

:global(.hit-desc) {
  color: var(--grey-9);
  font-size: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* --- 4. Language Switcher --- */
:global(.lang-btn-container) {
  position: relative;
  display: flex;
  align-items: center;
  height: 100%;
}

:global(#lang-list) {
  position: absolute;
  top: 100%;
  left: 50%;
  width: 90px;
  padding: 0;
  margin: 0;
  list-style: none;
  z-index: 1000;
  background: var(--color-header-background);
  backdrop-filter: blur(12px);
  border-radius: 0 0 8px 8px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-top: none;
  box-shadow: 0 10px 15px rgba(0, 0, 0, 0.05);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform-origin: top;
  transform: translateX(-50%) scaleY(0.8);
  transition: transform 0.2s ease, opacity 0.2s ease, visibility 0.2s;
}

:global(#lang-list.show) {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(-50%) scaleY(1);
}

:global(#lang-list li) {
  padding: 12px 16px;
  font-size: 14px;
  color: var(--grey-9);
  text-align: center;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}

:global(#lang-list li:hover) {
  background: rgba(255, 0, 0, 0.05);
  color: var(--red-0);
}

:global(#lang-list li:last-child) {
  border-radius: 0 0 8px 8px;
}

/* --- 5. Miscs & Animations --- */
.triangle-badge {
  position: absolute;
  top: -6px;
  right: -26px;
  transform: rotate(45deg);
  width: 0;
  height: 0;
  border-left: 40px solid transparent;
  border-right: 40px solid transparent;
  border-bottom: 40px solid var(--red-2);
  display: inline-block;
  transition: 0.3s;

  @media screen and (max-width: 959px) {
    display: none;
  }
}

.triangle-badge-icon {
  position: absolute;
  top: 12px;
  left: -13px;
  color: var(--color-header-background) !important;
  font-size: 28px;
  transition: 0.3s;
}

#main-nav-toggle {
  display: none;
  @media screen and (max-width: 767px) {
    display: block;
  }
}

@keyframes fade-in-blur {
  0% { opacity: 0; filter: blur(10px); }
  100% { opacity: 1; filter: blur(0); }
}

@keyframes search-slide-in {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>